{
  "flutter": {
    "platforms": {
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "amplifymusic-c0035",
          "configurations": {
            "ios": "1:196671810782:ios:00fa98dc2dc6f305a1664f",
            "macos": "1:196671810782:ios:00fa98dc2dc6f305a1664f",
            "windows": "1:196671810782:web:420eedd81184fcb0a1664f"
          }
        }
      }
    }
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.json",
        "headers": [
          { "key": "Content-Type", "value": "application/json; charset=utf-8" },
          { "key": "Access-Control-Allow-Origin", "value": "*" },
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "**/*.{js,css,png,jpg,jpeg,gif,webp,svg,mp3,wav,ogg}",
        "headers": [
          { "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [
          { "key": "Content-Type", "value": "application/xml" },
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/sitemap.xml",
        "destination": "https://conhbihmsgdujpwhperh.supabase.co/functions/v1/sitemap"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}